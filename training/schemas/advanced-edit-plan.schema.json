{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AdvancedEditPlan",
  "type": "object",
  "required": ["operations"],
  "additionalProperties": false,
  "properties": {
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["op"],
        "additionalProperties": true,
        "properties": {
          "op": {
            "type": "string",
            "enum": [
              "trim",
              "cut",
              "zoom_in",
              "zoom_out",
              "pan",
              "rotate",
              "speed_ramp",
              "freeze_frame",
              "blur",
              "color_grade",
              "caption",
              "beat_sync",
              "transition"
            ]
          },
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "minimum": 0 },
          "at": { "type": "number", "minimum": 0 },
          "anchor": {
            "type": "string",
            "enum": ["center", "top", "bottom", "left", "right", "top-left", "top-right", "bottom-left", "bottom-right"]
          },
          "strength": { "type": "number", "minimum": 0.1, "maximum": 5 },
          "easing": { "type": "string", "enum": ["linear", "ease-in", "ease-out", "ease-in-out"] },
          "speed": { "type": "number", "minimum": 0.1, "maximum": 8 },
          "degrees": { "type": "number", "minimum": -360, "maximum": 360 },
          "direction": { "type": "string", "enum": ["left", "right", "up", "down"] },
          "preset": { "type": "string" },
          "text": { "type": "string", "minLength": 1, "maxLength": 120 },
          "intensity": { "type": "number", "minimum": 0, "maximum": 1 },
          "style": { "type": "string" }
        }
      }
    }
  }
}
